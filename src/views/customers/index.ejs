<%- include('../partials/header', { title: 'Customers' }) %>

    <div class="page-head">
  <h1>Customers</h1>
  <a class="btn-primary btn-small" href="/customers/new">+ เพิ่มใหม่</a>
</div>

<table class="booking-table">
  <thead>
    <tr>
      <th>ID</th>
      <th>ชื่อ</th>
      <th>Email</th>
      <th>เบอร์โทร</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% if (!customers.length) { %>
      <tr><td colspan="5" class="empty-state">ยังไม่มีข้อมูล</td></tr>
    <% } %>
    <% customers.forEach((customer) => { %>
      <tr>
        <td><%= customer.id %></td>
        <td><%= customer.fullname %></td>
        <td><%= customer.email %></td>
        <td><%= customer.phoneNumber %></td>
        <td class="action-row">
          <a class="btn-inline btn-small" href="/customers/<%= customer.id %>">ดู</a>
          <a class="btn-ghost btn-small" href="/customers/<%= customer.id %>/edit">แก้ไข</a>
          <form method="POST" action="/customers/<%= customer.id %>" onsubmit="return confirm('ยืนยันการลบลูกค้านี้?')">
            <input type="hidden" name="_method" value="DELETE" />
            <button class="btn-danger btn-small" type="submit">ลบ</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

<%- include('../partials/footer') %>
