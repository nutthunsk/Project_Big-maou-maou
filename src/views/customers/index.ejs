<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ลูกค้าธุรกิจ</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="site-body">
  <main class="page-shell">
    <div class="page-head">
      <h1>ลูกค้าธุรกิจ</h1>
      <div class="action-row">
        <a class="btn-inline" href="/customers/report">ดูรายงานเชิงธุรกิจ</a>
        <a class="btn-ghost btn-small" href="/">กลับหน้าแรก</a>
      </div>
    </div>

    <% if (customerRows.length === 0) { %>
      <p class="empty-state">ยังไม่มีข้อมูลลูกค้าธุรกิจ</p>
    <% } else { %>
      <table class="booking-table">
        <thead>
          <tr>
            <th>#</th>
            <th>ชื่อ-นามสกุล</th>
            <th>อีเมล</th>
            <th>เบอร์โทร</th>
            <th>จำนวนการจอง</th>
            <th>จองแล้วชำระ</th>
            <th>ยอดชำระสะสม</th>
            <th>จองล่าสุด</th>
          </tr>
        </thead>
        <tbody>
          <% customerRows.forEach((row, idx) => { %>
            <tr>
              <td><%= idx + 1 %></td>
              <td><%= row.customer.fullname %></td>
              <td><%= row.customer.email %></td>
              <td><%= row.customer.phoneNumber %></td>
              <td><%= row.totalBookings %></td>
              <td><%= row.paidBookings %></td>
              <td><%= row.totalSpent.toLocaleString() %> บาท</td>
              <td><%= row.lastBookingDate ? row.lastBookingDate.toLocaleString('th-TH') : '-' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </main>
</body>
</html>