<%- include('../partials/header', { title: 'Customers' }) %>

    <div class="page-head">
  <h1>Customers</h1>
</div>

<table class="booking-table">
  <thead>
    <tr>
      <th>ID</th>
      <th>Name</th>
      <th>Email</th>
      <th>Phone Number</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% if (!customers.length) { %>
      <tr><td colspan="5" class="empty-state">no information yet</td></tr>
    <% } %>
    <% customers.forEach((customer) => { %>
      <tr>
        <td><%= customer.id %></td>
        <td><%= customer.fullname %></td>
        <td><%= customer.email %></td>
        <td><%= customer.phoneNumber %></td>
        <td class="action-row table-actions">
          <a class="btn-inline btn-small" href="/customers/<%= customer.id %>">View</a>
          <a class="btn-ghost btn-small" href="/customers/<%= customer.id %>/edit">Edit</a>
          <form method="POST" action="/customers/<%= customer.id %>" onsubmit="return confirm('Confirm the deletion of this customer?')">
            <input type="hidden" name="_method" value="DELETE" />
            <button class="btn-danger btn-small" type="submit">Delete</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

<%- include('../partials/footer') %>
