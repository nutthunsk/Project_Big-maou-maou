<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>รายงานลูกค้าธุรกิจ</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="site-body">
  <main class="page-shell">
    <div class="page-head">
      <h1>รายงานลูกค้าธุรกิจ</h1>
      <a class="btn-ghost btn-small" href="/customers">กลับหน้าลูกค้า</a>
    </div>

    <div class="report-grid">
      <article class="report-card">
        <h3>จำนวนลูกค้า</h3>
        <p><%= totals.customers %> คน</p>
      </article>
      <article class="report-card">
        <h3>จำนวนการจองรวม</h3>
        <p><%= totals.bookings %> รายการ</p>
      </article>
      <article class="report-card">
        <h3>จองที่ชำระแล้ว</h3>
        <p><%= totals.paidBookings %> รายการ</p>
      </article>
      <article class="report-card">
        <h3>รายได้รวม</h3>
        <p><%= totals.revenue.toLocaleString() %> บาท</p>
      </article>
    </div>

    <h2>อันดับลูกค้าที่มียอดชำระสูงสุด</h2>
    <table class="booking-table">
      <thead>
        <tr>
          <th>อันดับ</th>
          <th>ลูกค้า</th>
          <th>อีเมล</th>
          <th>การจองทั้งหมด</th>
          <th>ชำระแล้ว</th>
          <th>ยอดชำระสะสม</th>
        </tr>
      </thead>
      <tbody>
        <% customerRows.forEach((row, idx) => { %>
          <tr>
            <td><%= idx + 1 %></td>
            <td><%= row.customer.fullname %></td>
            <td><%= row.customer.email %></td>
            <td><%= row.totalBookings %></td>
            <td><%= row.paidBookings %></td>
            <td><%= row.totalSpent.toLocaleString() %> บาท</td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </main>
</body>
</html>