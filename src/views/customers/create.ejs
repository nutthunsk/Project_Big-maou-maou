<%- include('../partials/header', { title: 'Create customer' }) %>

<h1>Add Customer</h1>

<form class="stack-form" method="POST" action="/customers">
  <label for="fullname">Customer Name</label>
  <input id="fullname" name="fullname" type="text" required maxlength="120" />

  <label for="email">Email</label>
  <input id="email" name="email" type="email" pattern="[^\s@]+@[^\s@]+\.[^\s@]+" title="Please enter a correct email address, for example: name@example.com" required maxlength="160" />

  <label for="phoneNumber">Phone Number</label>
  <input id="phoneNumber" name="phoneNumber" type="text" required pattern="[0-9]{8,15}" maxlength="15" />

  <div class="action-row">
    <button class="btn-primary" type="submit">Save</button>
    <a class="btn-ghost" href="/customers">Cancle</a>
  </div>
</form>

<%- include('../partials/footer') %>