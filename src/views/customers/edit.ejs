<%- include('../partials/header', { title: 'Edit customer' }) %>

<h1>Edit Customer</h1>

<form class="stack-form" method="POST" action="/customers/<%= customer.id %>">
  <input type="hidden" name="_method" value="PUT" />

  <label for="fullname">Customer Name</label>
  <input id="fullname" name="fullname" type="text" value="<%= customer.fullname %>" required maxlength="120" />

  <label for="email">Email</label>
  <input id="email" name="email" type="email" pattern="[^\s@]+@[^\s@]+\.[^\s@]+" title="Please enter a correct email address, for example: name@example.com" value="<%= customer.email %>" required maxlength="160" />

  <label for="phoneNumber">Phone Number</label>
  <input id="phoneNumber" name="phoneNumber" type="text" value="<%= customer.phoneNumber %>" required pattern="[0-9]{8,15}" maxlength="15" />

  <div class="action-row">
    <button class="btn-primary" type="submit">Update</button>
    <a class="btn-ghost" href="/customers/<%= customer.id %>">Cancle</a>
  </div>
</form>

<%- include('../partials/footer') %>