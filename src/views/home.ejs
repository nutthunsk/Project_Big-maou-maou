<%- include('partials/header', { title: 'Dashboard' }) %>

    <section class="page-head">
  <h1>BIG MAOU MAOU CONCERTS</h1>
</section>

    <section class="report-grid">
  <article class="report-card">
    <h3>Artists</h3>
    <p><%= stats.artistCount %></p>
  </article>
  <article class="report-card">
    <h3>Concerts</h3>
    <p><%= stats.concertCount %></p>
  </article>
  <article class="report-card">
    <h3>Customers</h3>
    <p><%= stats.customerCount %></p>
  </article>
</section>

  <section>
  <div class="page-head">
    <h2>รายการจองล่าสุด</h2>
    <a href="/bookings" class="btn-inline btn-small">ดูทั้งหมด</a>
  </div>

      <table class="booking-table">
    <thead>
      <tr>
        <th>Concert</th>
        <th>Customer</th>
        <th>Count</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% if (!latestBookings.length) { %>
        <tr>
          <td colspan="5" class="empty-state">ยังไม่มีรายการจอง</td>
        </tr>
      <% } %>
    <% latestBookings.forEach((booking) => { %>
        <tr>
          <td><%= booking.Concert ? booking.Concert.ConcertName : '-' %></td>
          <td><%= booking.Customer ? booking.Customer.fullname : '-' %></td>
          <td><%= booking.quantity %></td>
          <td><%= booking.status %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>

<%- include('partials/footer') %>