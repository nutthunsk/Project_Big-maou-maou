<%- include('../partials/user_header', { title: 'Forgot Password' }) %>

<section class="booking-form-layout user-login-layout">
  <div class="booking-form-card booking-form-card-main user-login-card">
    <h1>ลืมรหัสผ่าน</h1>
    <p class="booking-form-subtitle">ยืนยันอีเมลและเบอร์โทรเพื่อกำหนดรหัสผ่านใหม่</p>

    <% if (errorMessage) { %>
      <div class="flash flash-error"><%= errorMessage %></div>
    <% } %>

    <% if (successMessage) { %>
      <div class="flash flash-success"><%= successMessage %></div>
    <% } %>

    <form class="stack-form booking-create-form" method="POST" action="/user/forgot-password">
      <label for="email">อีเมล</label>
      <input id="email" name="email" type="email" value="<%= formValues?.email || '' %>" required />

      <label for="phoneNumber">เบอร์โทรศัพท์</label>
      <input id="phoneNumber" name="phoneNumber" type="tel" pattern="[0-9]{10}" maxlength="10" value="<%= formValues?.phoneNumber || '' %>" required />

      <label for="password">รหัสผ่านใหม่</label>
      <input id="password" name="password" type="password" minlength="8" required />
      <small class="muted-inline">อย่างน้อย 8 ตัวอักษร และต้องมีตัวอักษรภาษาอังกฤษกับตัวเลข</small>

      <label for="confirmPassword">ยืนยันรหัสผ่านใหม่</label>
      <input id="confirmPassword" name="confirmPassword" type="password" minlength="8" required />

      <div class="action-row">
        <button class="btn-primary" type="submit">รีเซ็ตรหัสผ่าน</button>
        <a class="btn-ghost" href="/user/login">กลับไปหน้าเข้าสู่ระบบ</a>
      </div>
    </form>
  </div>
</section>

<%- include('../partials/footer') %>