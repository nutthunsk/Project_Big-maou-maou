<%- include('../partials/user_header', { title: 'Booking receipt' }) %>

<section class="booking-form-layout">
  <article class="booking-form-card booking-form-card-main">
    <h1>preemption certificate #<%= booking.id %></h1>
    <p class="booking-form-subtitle">Your concert booking details</p>

    <% const concert = booking.Concert; %>
    <ul class="concert-meta-list">
      <li><strong>Booker's name:</strong> <%= booking.Customer ? booking.Customer.fullname : (customer ? customer.fullname : '-') %></li>
      <li><strong>Email:</strong> <%= booking.Customer ? booking.Customer.email : (customer ? customer.email : '-') %></li>
      <li><strong>Concert:</strong> <%= concert ? concert.ConcertName : '-' %></li>
      <li><strong>Date:</strong>
        <%= concert && concert.ConcertDate
          ? new Date(`${concert.ConcertDate}T00:00:00`).toLocaleDateString('th-TH', { day: '2-digit', month: 'short', year: 'numeric' })
          : '-' %>
      </li>
      <li><strong>Time:</strong> <%= concert && concert.ConcertTime ? String(concert.ConcertTime).slice(0, 5) : '-' %></li>
      <li><strong>Location:</strong> <%= concert ? concert.venue : '-' %></li>
      <li><strong>Artists:</strong>
        <%= concert && concert.Artists && concert.Artists.length
          ? concert.Artists.map((a) => a.ArtistName).join(', ')
          : '-' %>
      <li><strong>Number of tickets purchased:</strong> <%= receiptSummary ? receiptSummary.totalTicketsPurchased : booking.quantity %> blade</li>
      <li><strong>Total:</strong> ฿<%= Number(receiptSummary ? receiptSummary.totalAmount : booking.totalPrice || 0).toLocaleString() %></li>
      <li><strong>Status:</strong> <%= receiptSummary ? receiptSummary.latestStatus : booking.status %></li>
    </ul>

    <div class="action-row">
      <a class="btn-ghost" href="/user/profile">← Back to profile</a>
    </div>
  </article>
</section>

<%- include('../partials/footer') %>