<%- include('../partials/user_header', { title: 'User Home' }) %>

<section class="page-head">
  <h1>BIG MAOU MAOU CONCERTS</h1>
</section>

<section>
  <div class="page-head">
    <h2>Latest artists</h2>
    <a href="/user/artists" class="btn-inline btn-small">View all</a>
  </div>
  <ul class="concert-meta-list artist-concert-list">
    <% if (!latestArtists || !latestArtists.length) { %>
      <li class="empty-state">no artists yet</li>
    <% } else { %>
      <% latestArtists.forEach((artist) => { %>
        <li>
          <strong><%= artist.ArtistName %></strong>
          <span class="muted-inline">(<%= artist.genre %>)</span>
          <div class="muted-inline">Number of concerts: <%= artist.Concerts ? artist.Concerts.length : 0 %></div>
        </li>
      <% }) %>
    <% } %>
  </ul>
</section>

<section>
  <div class="page-head">
    <h2>Latest concerts</h2>
    <a href="/user/concerts" class="btn-inline btn-small">View all</a>
  </div>
  <ul class="concert-meta-list artist-concert-list">
    <% if (!latestConcerts || !latestConcerts.length) { %>
      <li class="empty-state">no concerts yet</li>
    <% } else { %>
      <% latestConcerts.forEach((concert) => {
        const d = concert.ConcertDate ? new Date(`${concert.ConcertDate}T00:00:00`) : null;
      %>
        <li>
          <strong><%= concert.ConcertName %></strong>
          <% if (d) { %>
            <span class="muted-inline">(
              <%= d.toLocaleDateString('th-TH', { day: '2-digit', month: 'short', year: 'numeric' }) %>
            )</span>
          <% } %>
        </li>
      <% }) %>
    <% } %>
  </ul>
</section>

<%- include('../partials/footer') %>