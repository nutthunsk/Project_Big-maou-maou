<%- include('../partials/user_header', { title: 'User Home' }) %>

<section class="discover-hero">
  <p class="discover-kicker">THE CONCERT</p>
  <h1>DISCOVER</h1>
</section>

<section class="discover-section">
  <div class="page-head discover-head">
    <h2>Latest concerts</h2>
    <a href="/user/concerts" class="btn-inline btn-small">ดูเพิ่มเติม</a>
  </div>
  
  <div class="discover-card-grid">
    <% if (!latestConcerts || !latestConcerts.length) { %>
      <p class="empty-state">no concerts yet</p>
    <% } else { %>
      <% latestConcerts.forEach((concert) => {
        const d = concert.ConcertDate ? new Date(`${concert.ConcertDate}T00:00:00`) : null;
      %>
        <article class="discover-card">
          <div class="discover-poster"><img class="user-concert-poster" src="/images/Poster.png" alt="<%= concert.ConcertName %> poster" /></div>
          <div class="discover-card-body">
            <h3><%= concert.ConcertName %></h3>
            <% if (d) { %>
              <p><%= d.toLocaleDateString('th-TH', { day: '2-digit', month: 'short', year: 'numeric' }) %></p>
            <% } else { %>
              <p>-</p>
            <% } %>
          </div>
        </article>
      <% }) %>
    <% } %>
  </div>
</section>

<%- include('../partials/footer') %>