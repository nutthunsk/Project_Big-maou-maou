<%- include('../partials/user_header', { title: 'Profile' }) %>

<section class="booking-form-layout">
  <div class="booking-form-card booking-form-card-main">
    <h1>User information</h1>
    <p class="booking-form-subtitle">You can edit your personal information on this page</p>

    <form class="stack-form booking-create-form" method="POST" action="/user/profile">
      <label for="fullname">Name - Surname</label>
      <input id="fullname" name="fullname" type="text" minlength="2" maxlength="120" value="<%= customer ? customer.fullname : '' %>" required />

      <label for="email">Email</label>
      <input id="email" name="email" type="email" value="<%= customer ? customer.email : '' %>" required />

      <label for="phoneNumber">=Phone number</label>
      <input id="phoneNumber" name="phoneNumber" type="tel" pattern="[0-9]{8,15}" maxlength="15" value="<%= customer ? customer.phoneNumber : '' %>" required />

      <div class="action-row">
        <button class="btn-primary" type="submit">Save data</button>
        <a class="btn-ghost" href="/user">Return to Home page</a>
      </div>
    </form>
  </div>
</section>

<section class="profile-booking-section">
  <div class="page-head">
    <h2>The concert you booked</h2>
  </div>

  <% if (!concertBookings || concertBookings.length === 0) { %>
    <p class="empty-state">There are no concert bookings available yet</p>
  <% } else { %>
    <div class="concert-grid compact-grid">
      <% concertBookings.forEach((item) => {
        const concert = item.concert;
        const dateObj = concert?.ConcertDate ? new Date(`${concert.ConcertDate}T00:00:00`) : null;
        const displayDate = dateObj
          ? dateObj.toLocaleDateString('th-TH', { day: '2-digit', month: 'short', year: 'numeric' })
          : '-';
      %>
        <article class="concert-card compact-card profile-booking-card">
          <h3 class="concert-title"><%= concert ? concert.ConcertName : 'Unknown concert' %></h3>
          <ul class="concert-meta-list">
            <li><strong>วันแสดง:</strong> <%= displayDate %></li>
            <li><strong>สถานที่:</strong> <%= concert ? concert.venue : '-' %></li>
            <li><strong>ศิลปิน:</strong>
              <%= concert && concert.Artists && concert.Artists.length
                ? concert.Artists.map((a) => a.ArtistName).join(', ')
                : '-' %>
            </li>
            <li><strong>จำนวนบัตรที่ซื้อแล้ว:</strong> <%= item.totalTicketsPurchased %> ใบ</li>

            <li><strong>ยอดรวม:</strong> ฿<%= Number(item.totalAmount || 0).toLocaleString() %></li>
          </ul>
          <p class="profile-booking-status status-<%= item.latestStatus %>">
            สถานะล่าสุด: <strong><%= item.latestStatus %></strong>
          </p>
        </article>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include('../partials/footer') %>