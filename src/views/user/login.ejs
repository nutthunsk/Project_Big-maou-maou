<%- include('../partials/user_header', { title: 'Login' }) %>

<section class="booking-form-layout user-login-layout">
  <div class="booking-form-card booking-form-card-main user-login-card">
    <h1>User login</h1>
    <p class="booking-form-subtitle">Log in with your email and password to book your concert tickets</p>

    <% if (errorMessage) { %>
      <div class="flash flash-error"><%= errorMessage %></div>
    <% } %>

    <% if (successMessage) { %>
      <div class="flash flash-success"><%= successMessage %></div>
    <% } %>

    <form class="stack-form booking-create-form" method="POST" action="/user/login">
      <input type="hidden" name="redirectTo" value="<%= redirectTo || '/user/concerts' %>" />

      <label for="email">Email</label>
      <input
        id="email"
        name="email"
        type="email"
        value="<%= formValues?.email || '' %>"
        required
      />

      <label for="password">Password</label>
      <input id="password" name="password" type="password" minlength="8" required />

      <div class="action-row">
        <button class="btn-primary" type="submit">Login</button>
        <a class="btn-ghost" href="/user/register?redirect=<%= encodeURIComponent(redirectTo || '/user/concerts') %>">Apply for new membership</a>
        <a class="btn-ghost" href="/user/forgot-password">Forgot your password</a>
      </div>
    </form>
  </div>
</section>

<%- include('../partials/footer') %>