<%- include('../partials/user_header', { title: 'Register' }) %>

<section class="booking-form-layout user-login-layout">
  <div class="booking-form-card booking-form-card-main user-login-card">
    <h1>Apply for user membership</h1>
    <p class="booking-form-subtitle">Create a new account to use the user-side ticket booking system</p>

    <% if (errorMessage) { %>
      <div class="flash flash-error"><%= errorMessage %></div>
    <% } %>

    <form class="stack-form booking-create-form" method="POST" action="/user/register">
      <input type="hidden" name="redirectTo" value="<%= redirectTo || '/user/concerts' %>" />

      <label for="fullname">Name - Surname</label>
      <input id="fullname" name="fullname" type="text" minlength="2" maxlength="120" value="<%= formValues?.fullname || '' %>" required />

      <label for="email">Email</label>
      <input id="email" name="email" type="email" value="<%= formValues?.email || '' %>" required />

      <label for="phoneNumber">Phone number</label>
      <input id="phoneNumber" name="phoneNumber" type="tel" pattern="[0-9]{10}" maxlength="10" value="<%= formValues?.phoneNumber || '' %>" required />

      <label for="password">Password</label>
      <input id="password" name="password" type="password" minlength="8" required />
      <small class="muted-inline">At least 8 characters, and must contain English letters and numbers</small>

      <label for="confirmPassword">Confirm password</label>
      <input id="confirmPassword" name="confirmPassword" type="password" minlength="8" required />

      <div class="action-row">
        <button class="btn-primary" type="submit">Apply for membership</button>
        <a class="btn-ghost" href="/user/login?redirect=<%= encodeURIComponent(redirectTo || '/user/concerts') %>">Return to the login page</a>
      </div>
    </form>
  </div>
</section>

<%- include('../partials/footer') %>