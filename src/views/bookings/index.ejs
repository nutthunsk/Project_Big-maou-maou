<%- include('../partials/header', { title: 'Bookings' }) %>

  <div class="page-head">
  <h1>Bookings</h1>
  <a class="btn-primary btn-small" href="/bookings/new">+ เพิ่มใหม่</a>
</div>

<table class="booking-table">
  <thead>
    <tr>
      <th>ID</th>
      <th>Concert</th>
      <th>Customer</th>
      <th>Qty</th>
      <th>Total</th>
      <th>Status</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% if (!bookings.length) { %>
      <tr><td colspan="7" class="empty-state">ยังไม่มีข้อมูล</td></tr>
    <% } %>

<% bookings.forEach((booking) => { %>
      <tr>
        <td><%= booking.id %></td>
        <td><%= booking.Concert ? booking.Concert.ConcertName : '-' %></td>
        <td><%= booking.Customer ? booking.Customer.fullname : '-' %></td>
        <td><%= booking.quantity %></td>
        <td><%= Number(booking.totalPrice).toLocaleString() %></td>
        <td><%= booking.status %></td>
        <td class="action-row">
          <a class="btn-inline btn-small" href="/bookings/<%= booking.id %>">ดู</a>
          <a class="btn-ghost btn-small" href="/bookings/<%= booking.id %>/edit">แก้ไข</a>
          <form method="POST" action="/bookings/<%= booking.id %>" onsubmit="return confirm('ยืนยันการลบรายการจองนี้?')">
            <input type="hidden" name="_method" value="DELETE" />
            <button class="btn-danger btn-small" type="submit">ลบ</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

<%- include('../partials/footer') %>