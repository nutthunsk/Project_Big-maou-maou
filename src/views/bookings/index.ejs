<%- include('../partials/header', { title: 'Bookings' }) %>

  <div class="page-head">
  <h1>Bookings</h1>
</div>

<table class="booking-table">
  <thead>
    <tr>
      <th>ID</th>
      <th>Concert</th>
      <th>Customer</th>
      <th>Qty</th>
      <th>Total</th>
      <th>Status</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% if (!bookings.length) { %>
      <tr><td colspan="7" class="empty-state">no information yet</td></tr>
    <% } %>

<% bookings.forEach((booking) => { %>
      <tr>
        <td><%= booking.id %></td>
        <td><%= booking.Concert ? booking.Concert.ConcertName : '-' %></td>
        <td><%= booking.Customer ? booking.Customer.fullname : '-' %></td>
        <td><%= booking.quantity %></td>
        <td><%= Number(booking.totalPrice).toLocaleString() %></td>
        <td><%= booking.status %></td>
        <td class="action-row table-actions">
                  <% if (booking.status !== 'paid') { %>
            <form method="POST" action="/bookings/<%= booking.id %>/mark-paid" onsubmit="return confirm('Confirmed status update to paid?')">
              <button class="btn-primary btn-small" type="submit">Successfully scanned and paid</button>
            </form>
          <% } else { %>
            <form method="POST" action="/bookings/<%= booking.id %>/mark-pending" onsubmit="return confirm('Confirm simulated status as pending?')">
              <button class="btn-ghost btn-small" type="submit">The simulation is not yet paid.</button>
              
            </form>
          <% } %>
          <a class="btn-ghost btn-small" href="/bookings/<%= booking.id %>/edit">Edit</a>
          <form method="POST" action="/bookings/<%= booking.id %>" onsubmit="return confirm('Confirm the deletion of this booking?')">
            <input type="hidden" name="_method" value="DELETE" />
            <button class="btn-danger btn-small" type="submit">Deleat</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

<%- include('../partials/footer') %>