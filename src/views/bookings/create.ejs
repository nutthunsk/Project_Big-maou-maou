<% if (authCustomer) { %>
  <%- include('../partials/user_header', { title: 'Reserve concert tickets' }) %>
<% } else { %>
  <%- include('../partials/header', { title: 'Reserve concert tickets' }) %>
<% } %>

<section class="booking-form-layout">
  <div class="booking-form-card booking-form-card-main">
    <h1>Reserve concert tickets</h1>
    <p class="booking-form-subtitle">Enter the booking information and the number of tickets required. The system will immediately save it to your booking</p>

    <form class="stack-form booking-create-form" method="POST" action="/bookings">
      <% if (selectedConcert) { %>
        <input type="hidden" name="ConcertId" value="<%= selectedConcert.id %>" />
        <div class="selected-concert-box">
          <p class="selected-concert-label">Selected concert reservation</p>
          <h3><%= selectedConcert.ConcertName %></h3>
          <p class="muted-inline"><%= selectedConcert.venue %> · <%= Number(selectedConcert.price).toLocaleString() %> Bath</p>
        </div>
      <% } else { %>
        <label for="ConcertId">Choose a concert</label>
        <select id="ConcertId" name="ConcertId" required>
          <option value="">Select the concert you want to reserve</option>
          <% concerts.forEach((concert) => { %>
            <option value="<%= concert.id %>" <%= Number(selectedConcertId) === Number(concert.id) ? 'selected' : '' %>>
              <%= concert.ConcertName %> · <%= concert.venue %> · <%= Number(concert.price).toLocaleString() %> Bath
            </option>
          <% }) %>
        </select>
      <% } %>

      <div class="booking-create-grid">
        <div>
          <label for="fullname">Name and surname</label>
          <input id="fullname" name="fullname" type="text" minlength="2" maxlength="120" placeholder=For example, Somchai Jaidee" value="<%= authCustomer ? authCustomer.fullname : "" %>" required />
        </div>

        <div>
          <label for="phoneNumber">Phon Number</label>
          <input id="phoneNumber" name="phoneNumber" type="tel" placeholder="08xxxxxxxx" pattern="[0-9]{8,15}" maxlength="15" value="<%= authCustomer ? authCustomer.phoneNumber : "" %>" required />
        </div>
      </div>

      <label for="email">Email for confirmation</label>
      <input id="email" name="email" type="email" pattern="[^\s@]+@[^\s@]+\.[^\s@]+" title="Please enter a correct email address, for example name@example.com" placeholder="example@email.com" value="<%= authCustomer ? authCustomer.email : "" %>" <%= authCustomer ? "readonly" : "" %> required />

      <div class="booking-create-grid">
        <div>
          <label for="quantity">Number of ticket</label>
          <input id="quantity" name="quantity" type="number" min="1" max="<%= maxBookingQty %>" value="1" required />
          <small class="help-text">You can reserve no more than <%= maxBookingQty %> per item</small>
        </div>

        <div>
          <label>Payment status (simulated)</label>
          <input id="status" name="status" type="hidden" value="pending" />
          <div class="payment-sim-box">
            <div class="mock-qr">QR</div>
            <div>
              <div id="paymentStatusText" class="payment-status payment-pending">Payment pending(simulated)</div>
              <div class="payment-sim-actions">
                <button type="button" class="btn-primary btn-small" id="btnMockPaid">Successfully scanned and paid</button>
                <button type="button" class="btn-ghost btn-small" id="btnMockPending">The simulation is not yet paid</button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="action-row">
        <button class="btn-primary" type="submit">Confirm booking</button>
        <a class="btn-ghost" href="/user">Return to home page</a>
      </div>
    </form>
  </div>
  </section>

<script>
  (() => {
    const statusInput = document.getElementById('status');
    const statusText = document.getElementById('paymentStatusText');
    const paidBtn = document.getElementById('btnMockPaid');
    const pendingBtn = document.getElementById('btnMockPending');

    if (!statusInput || !statusText || !paidBtn || !pendingBtn) return;

    const setStatus = (value) => {
      statusInput.value = value;
      if (value === 'paid') {
        statusText.textContent = 'Paid (paid)';
        statusText.className = 'payment-status payment-paid';
        return;
      }

      statusText.textContent = 'Not yet paid (pending)';
      statusText.className = 'payment-status payment-pending';
    };

    paidBtn.addEventListener('click', () => setStatus('paid'));
    pendingBtn.addEventListener('click', () => setStatus('pending'));
  })();
</script>

<%- include('../partials/footer') %>
