<%- include('../partials/header', { title: 'จองบัตรคอนเสิร์ต' }) %>

<section class="booking-form-layout">
  <div class="booking-form-card booking-form-card-main">
    <h1>จองบัตรคอนเสิร์ต</h1>
    <p class="booking-form-subtitle">กรอกข้อมูลผู้จองและจำนวนบัตรที่ต้องการ ระบบจะบันทึกลงรายการ booking ให้ทันที</p>

    <form class="stack-form booking-create-form" method="POST" action="/bookings">
      <% if (selectedConcert) { %>
        <input type="hidden" name="ConcertId" value="<%= selectedConcert.id %>" />
        <div class="selected-concert-box">
          <p class="selected-concert-label">คอนเสิร์ตที่เลือกจอง</p>
          <h3><%= selectedConcert.ConcertName %></h3>
          <p class="muted-inline"><%= selectedConcert.venue %> · <%= Number(selectedConcert.price).toLocaleString() %> บาท</p>
        </div>
      <% } else { %>
        <label for="ConcertId">เลือกคอนเสิร์ต</label>
        <select id="ConcertId" name="ConcertId" required>
          <option value="">เลือกคอนเสิร์ตที่ต้องการจอง</option>
          <% concerts.forEach((concert) => { %>
            <option value="<%= concert.id %>" <%= Number(selectedConcertId) === Number(concert.id) ? 'selected' : '' %>>
              <%= concert.ConcertName %> · <%= concert.venue %> · <%= Number(concert.price).toLocaleString() %> บาท
            </option>
          <% }) %>
        </select>
      <% } %>

      <div class="booking-create-grid">
        <div>
          <label for="fullname">ชื่อ-นามสกุลผู้จอง</label>
          <input id="fullname" name="fullname" type="text" minlength="2" maxlength="120" placeholder="เช่น สมชาย ใจดี" required />
        </div>

        <div>
          <label for="phoneNumber">เบอร์โทรศัพท์</label>
          <input id="phoneNumber" name="phoneNumber" type="tel" placeholder="08xxxxxxxx" pattern="[0-9]{8,15}" maxlength="15" required />
        </div>
      </div>

      <label for="email">อีเมลสำหรับรับการยืนยัน</label>
      <input id="email" name="email" type="email" pattern="[^\s@]+@[^\s@]+\.[^\s@]+" title="กรอกอีเมลให้ถูกต้อง เช่น name@example.com" placeholder="example@email.com" required />

      <div class="booking-create-grid">
        <div>
          <label for="quantity">จำนวนบัตร</label>
          <input id="quantity" name="quantity" type="number" min="1" max="<%= maxBookingQty %>" value="1" required />
          <small class="help-text">จองได้ไม่เกิน <%= maxBookingQty %> ใบต่อรายการ</small>
        </div>

        <div>
          <label>สถานะการชำระ (จำลอง)</label>
          <input id="status" name="status" type="hidden" value="pending" />
          <div class="payment-sim-box">
            <div class="mock-qr">QR</div>
            <div>
              <div id="paymentStatusText" class="payment-status payment-pending">ยังไม่ชำระ (pending)</div>
              <div class="payment-sim-actions">
                <button type="button" class="btn-primary btn-small" id="btnMockPaid">สแกนจ่ายสำเร็จ</button>
                <button type="button" class="btn-ghost btn-small" id="btnMockPending">จำลองยังไม่ชำระ</button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="action-row">
        <button class="btn-primary" type="submit">ยืนยันการจอง</button>
        <a class="btn-ghost" href="/concerts">กลับหน้าคอนเสิร์ต</a>
      </div>
    </form>
  </div>
  </section>

<script>
  (() => {
    const statusInput = document.getElementById('status');
    const statusText = document.getElementById('paymentStatusText');
    const paidBtn = document.getElementById('btnMockPaid');
    const pendingBtn = document.getElementById('btnMockPending');

    if (!statusInput || !statusText || !paidBtn || !pendingBtn) return;

    const setStatus = (value) => {
      statusInput.value = value;
      if (value === 'paid') {
        statusText.textContent = 'ชำระแล้ว (paid)';
        statusText.className = 'payment-status payment-paid';
        return;
      }

      statusText.textContent = 'ยังไม่ชำระ (pending)';
      statusText.className = 'payment-status payment-pending';
    };

    paidBtn.addEventListener('click', () => setStatus('paid'));
    pendingBtn.addEventListener('click', () => setStatus('pending'));
  })();
</script>

<%- include('../partials/footer') %>
