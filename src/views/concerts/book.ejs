<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ฺBooking - <%= concert.ConcertName %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="site-body booking-page">
  <main class="booking-shell booking-shell-reference">
    <div class="booking-topbar">
      <a href="/user/concerts" class="booking-back">← Back</a>
      <button type="button" id="themeToggleBtn" class="btn-ghost btn-small booking-theme-toggle">Dark</button>
    </div>

    <section class="booking-hero booking-hero-reference">
      <div class="poster-wrap">
        <div class="poster-glow"></div>
        <div class="poster-card poster-card-reference">
          <img
            class="poster-image"
            src="<%= concert.imagePath || '/images/Poster.png' %>"
            alt="<%= concert.ConcertName %> poster"
          />
          <div class="poster-card-fallback">
            <div class="poster-meta">BIG MAOU MAOU PRESENTS</div>
            <div class="poster-title"><%= concert.ConcertName %></div>
            <div class="poster-sub">
              <%= concert.Artists && concert.Artists.length ? concert.Artists.map(a => a.ArtistName).join(', ') : 'Main Artist' %>
            </div>
          </div>
        </div>
      </div>

      <div class="booking-info booking-info-reference">
        <span><h1><%= concert.ConcertName %></h1></span>

        <% 
          const eventDateObj = concert.ConcertDate
            ? new Date(`${concert.ConcertDate}T${concert.ConcertTime || '00:00:00'}+07:00`)
            : null;
          const displayDate = eventDateObj
            ? eventDateObj.toLocaleDateString('th-TH', { day: '2-digit', month: 'short', year: 'numeric' })
            : '-';
          const concertTimeText = String(concert.ConcertTime || '00:00:00');
          const [timeHour = '00', timeMinute = '00'] = concertTimeText.split(':');
          const displayTime = `${timeHour.padStart(2, '0')}:${timeMinute.padStart(2, '0')}`;
        %>

        <ul class="event-meta">
          <li> Event date: <strong><%= displayDate %></strong></li>
          <li> Time: <strong><%= displayTime %> น.</strong></li>
          <li> Location: <strong><%= concert.venue %></strong></li>
          <li>
            Artist: <strong>
            <%= concert.Artists && concert.Artists.length
              ? concert.Artists.map(a => a.ArtistName).join(', ')
              : '-' %>
            </strong>
          </li>
        </ul>
        <% const todayText = new Date().toISOString().slice(0, 10); %>
        <% const isPastConcert = String(concert.ConcertDate) < todayText; %>
        <section class="ticket-bar ticket-bar-compact">
          <div>
            <p class="ticket-label">Starting Price :</p>
            <p class="ticket-price">฿<%= Number(concert.price).toLocaleString() %></p>
          </div>

          <% if (isPastConcert) { %>
            <button class="ticket-buy-btn" type="button" disabled>Concert ended</button>
          <% } else if (concert.seatStats.isSoldOut) { %>
            <button class="ticket-buy-btn" type="button" disabled>Sold out</button>
          <% } else { %>
            <center><a href="/bookings/new?concertId=<%= concert.id %>" class="ticket-buy-btn">Tickets</a></center>
          <% } %>
        </section>
      </div>
    </section>

    <section class="booking-detail-card">
      <h2>Ticket Details</h2>
      <ul>
        <li>Tickets are available for purchase exclusively through the Big Maou Maou system</li>
        <li>starting price <strong>฿<%= Number(concert.price).toLocaleString() %></strong> Per seat</li>
        <li>Limit of 6 items per order</li>
        <li>Please double check your name, email address, and phone number before confirming</li>
        <li>After successful payment, a booking confirmation will be sent to your email</li>
      </ul>
    </section>

  </main>
  
<script>
  (() => {
    const storageKey = "site-theme";
    const root = document.documentElement;
    const btn = document.getElementById("themeToggleBtn");

    const applyTheme = (theme) => {
      root.setAttribute("data-theme", theme);
      if (!btn) return;
      btn.textContent = theme === "light" ? "Light" : "Dark";
    };

    const savedTheme = localStorage.getItem(storageKey);
    const theme = savedTheme === "light" ? "light" : "dark";
    applyTheme(theme);

    if (!btn) return;
    btn.addEventListener("click", () => {
      const current = root.getAttribute("data-theme") || "dark";
      const next = current === "dark" ? "light" : "dark";
      localStorage.setItem(storageKey, next);
      applyTheme(next);
    });
  })();
</script>

</body>
</html>