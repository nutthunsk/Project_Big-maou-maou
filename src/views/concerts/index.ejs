<!DOCTYPE html>
<html>
<head>
  <title>Concerts</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="dark-theme">
  <h1>Concerts</h1>

  <div class="action-row">
    <a class="btn-inline" href="/customers">หน้าลูกค้า</a>
    <a class="btn-inline" href="/customers/report">รายงานลูกค้า</a>
    <a class="btn-inline" href="/bookings">รายการจอง</a>
  </div>

  <% if (concerts.length === 0) { %>
    <p>ยังไม่มีคอนเสิร์ต</p>
  <% } %>

  <div class="concert-list">
    <% concerts.forEach(c => { %>
      <div class="concert-card">
        <h2><%= c.ConcertName %></h2>
        <p>
          ศิลปิน:
          <%= c.Artists && c.Artists.length
            ? c.Artists.map(a => a.ArtistName).join(", ")
            : "-" %>
        </p>
        <p>สถานที่: <%= c.venue %></p>
        <p>ราคา: <%= c.price %> บาท</p>

        <a class="btn" href="/concerts/<%= c.id %>/book">
           จองบัตร
        </a>
        <form action="/concerts/<%= c.id %>/delete" method="POST"
            onsubmit="return confirm('แน่ใจว่าจะลบคอนเสิร์ตนี้?')">
          <button type="submit" style="color:red">
          ลบคอนเสิร์ต
          </button>
        </form>
      </div>
    <% }) %>
  </div>
</body>
</html>