<%- include('../partials/header', { title: 'คอนเสิร์ต' }) %>

<div class="page-head">
  <h1>คอนเสิร์ต</h1>
  <div class="page-actions">
    <a class="btn-primary btn-small" href="/concerts/new">+ เพิ่มคอนเสิร์ต</a>
    <a class="btn-ghost btn-small" href="/">กลับหน้าหลัก</a>
  </div>
</div>

<section class="concert-grid compact-grid">
  <% if (!concerts || concerts.length === 0) { %>
    <p class="empty-state">ยังไม่มีคอนเสิร์ตในระบบ</p>
  <% } %>

  <% concerts.forEach((concert) => {
    const total = concert.seatStats?.totalSeats || 0;
    const booked = concert.seatStats?.bookedSeats || 0;
    const remaining = concert.seatStats?.remainingSeats || 0;
    const dateObj = new Date(`${concert.ConcertDate}T00:00:00`);
    const displayDate = dateObj.toLocaleDateString('th-TH', {
      weekday: 'short',
      year: 'numeric',
      month: 'short',
      day: 'numeric'
    });
    const displayTime = dateObj.toLocaleTimeString('th-TH', {
      hour: '2-digit',
      minute: '2-digit'
    })
  %>
    <article class="concert-card compact-card concert-card-clickable" onclick="window.location.href='/concerts/<%= concert.id %>/book'" 
      role="link" tabindex="0" onkeydown="if(event.key==='Enter'||event.key===' ')
      {event.preventDefault();window.location.href='/concerts/<%= concert.id %>/book';}">
      <h3 class="concert-title"><%= concert.ConcertName %></h3>

      <ul class="concert-meta-list">
        <li><strong>วันแสดง:</strong> <%= displayDate %></li>
        <li><strong>เวลา:</strong> <%= displayTime %> น.</li>
        <li>
          <strong>ศิลปิน/ผู้จัด:</strong>
          <%= concert.Artists && concert.Artists.length
            ? concert.Artists.map(a => a.ArtistName).join(', ')
            : '-' %>
        </li>
        <li><strong>สถานที่:</strong> <%= concert.venue %></li>
        <li><strong>ราคาเริ่มต้น:</strong> <%= Number(concert.price).toLocaleString() %> บาท</li>
        <li><strong>ที่นั่งทั้งหมด:</strong> <%= total %> ที่นั่ง</li>
        <li><strong>จองแล้ว:</strong> <%= booked %> ที่นั่ง</li>
        <li><strong>คงเหลือ:</strong> <%= remaining %> ที่นั่ง</li>
      </ul>

        <a class="btn-inline btn-small" href="/concerts/<%= concert.id %>/edit">
          แก้ไข
        </a>

        <form method="POST"
              action="/concerts/<%= concert.id %>"
              onsubmit="event.stopPropagation(); return confirm('ยืนยันการลบคอนเสิร์ตนี้?')">
          <input type="hidden" name="_method" value="DELETE">
          <button class="btn-danger btn-small" type="submit">
            ลบคอนเสิร์ต
          </button>
        </form>
      </div>
    </article>
  <% }) %>
</section>

<%- include('../partials/footer') %>