<%- include('../partials/header', { title: 'Concerts' }) %>\
<div class="page-head">
  <h1>Concerts</h1>
  <a class="btn-primary btn-small" href="/concerts/new">+ เพิ่มใหม่</a>
</div>

<table class="booking-table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Venue</th>
      <th>Date</th>
      <th>Artists</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% if (!concerts || concerts.length === 0) { %>
      <tr>
        <td colspan="5" class="empty-state">ยังไม่มีข้อมูล</td>
      </tr>
    <% } else { %>
      <% concerts.forEach(function (concert) { %>
        <tr>
          <td><%= concert.ConcertName %></td>
          <td><%= concert.venue %></td>
          <td><%= concert.ConcertDate %></td>
          <td>
            <%
              var artistNames = '-';
              if (concert.Artists && concert.Artists.length > 0) {
                artistNames = concert.Artists.map(function (artist) {
                  return artist.ArtistName;
                }).join(', ');
              }
            %>
            <%= artistNames %>
          </td>
          <td class="action-row">
            <a class="btn-inline btn-small" href="/concerts/<%= concert.id %>">ดู</a>
            <a class="btn-ghost btn-small" href="/concerts/<%= concert.id %>/edit">แก้ไข</a>
            <form method="POST" action="/concerts/<%= concert.id %>" onsubmit="return confirm('ยืนยันการลบคอนเสิร์ตนี้?')">
              <input type="hidden" name="_method" value="DELETE" />
              <button class="btn-danger btn-small" type="submit">ลบ</button>
            </form>
          </td>
        </tr>
      <% }); %>
    <% } %>
    </tbody>
</table>

<%- include('../partials/footer') %>