<%- include('../partials/header', { title: 'Edit concert' }) %>

<h1>แก้ไข Concert</h1>

<form class="stack-form" method="POST" action="/concerts/<%= concert.id %>">
  <input type="hidden" name="_method" value="PUT" />

  <label for="ConcertName">ชื่อคอนเสิร์ต</label>
  <input id="ConcertName" name="ConcertName" type="text" value="<%= concert.ConcertName %>" required maxlength="150" />

  <label for="venue">สถานที่</label>
  <input id="venue" name="venue" type="text" value="<%= concert.venue %>" required maxlength="120" />

  <label for="ConcertDate">วันที่</label>
    <input id="ConcertDate" name="ConcertDate" type="date" min="<%= new Date().toISOString().slice(0, 10) %>" value="<%= concert.ConcertDate %>" required />

  <label for="totalSeats">จำนวนที่นั่ง</label>
  <input id="totalSeats" name="totalSeats" type="number" min="1" value="<%= concert.totalSeats %>" required />

  <label for="price">ราคา</label>
  <input id="price" name="price" type="number" min="1" step="0.01" value="<%= concert.price %>" required />

  <label for="ArtistIds">ศิลปิน (เลือกได้หลายคน)</label>
  <%
    const selectedArtistIds = (concert.Artists || []).map((artist) => Number(artist.id));
    if (!selectedArtistIds.length && concert.ArtistId) selectedArtistIds.push(Number(concert.ArtistId));
  %>
  <select id="ArtistIds" name="ArtistIds" multiple required size="6">
    <% (artists || []).forEach(function (artist) { %>
      <option value="<%= artist.id %>" <%= selectedArtistIds.includes(Number(artist.id)) ? 'selected' : '' %>>
        <%= artist.ArtistName %>
      </option>
    <% }); %>
  </select>

  <small class="help-text">เลือกหลายคน: กด Ctrl/Cmd + คลิก</small>
  <div id="selected-artist-tags" class="selected-tags"></div>

  <div class="action-row">
    <button class="btn-primary" type="submit">อัปเดต</button>
    <a class="btn-ghost" href="/concerts/<%= concert.id %>">ยกเลิก</a>
  </div>
</form>

<script>
  (function () {
    const select = document.getElementById('ArtistIds');
    const tagsWrap = document.getElementById('selected-artist-tags');

    function renderTags() {
      tagsWrap.innerHTML = '';
      Array.from(select.selectedOptions).forEach((option) => {
        const tag = document.createElement('span');
        tag.className = 'selected-tag';
        tag.innerHTML = `${option.text} <button type="button" aria-label="remove">×</button>`;

        tag.querySelector('button').addEventListener('click', () => {
          option.selected = false;
          renderTags();
        });

        tagsWrap.appendChild(tag);
      });
    }

    select.addEventListener('change', renderTags);
    renderTags();
  })();
</script>

<%- include('../partials/footer') %>