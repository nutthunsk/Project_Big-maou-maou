<%- include('../partials/header', { title: 'Concert detail' }) %>

<h1><%= concert.ConcertName %></h1>
<p><strong>Venue:</strong> <%= concert.venue %></p>
<p><strong>Date:</strong> <%= concert.ConcertDate %></p>
<p>
  <strong>Artists:</strong>
  <%
    var artistNames = '-';
    if (concert.Artists && concert.Artists.length > 0) {
      artistNames = concert.Artists.map(function (artist) {
        return artist.ArtistName;
      }).join(', ');
    }
  %>
  <%= artistNames %>
</p>
<p><strong>Total Seats:</strong> <%= concert.totalSeats %></p>
<p><strong>Price:</strong> <%= Number(concert.price).toLocaleString() %> Bath</p>

<h2>Total number of reservations: <%= (concert.Bookings || []).length %></h2>

<div class="action-row">
  <a class="btn-primary" href="/bookings/new?concertId=<%= concert.id %>">Reserve tickets</a>
  <a class="btn-inline" href="/concerts/<%= concert.id %>/edit">Edit</a>
  <a class="btn-ghost" href="/concerts">Back</a>
  <form method="POST" action="/concerts/<%= concert.id %>" onsubmit="return confirm('Confirm the deletion of this concert?')">
    <input type="hidden" name="_method" value="DELETE" />
    <button class="btn-danger" type="submit">Delete</button>
  </form>
</div>

<%- include('../partials/footer') %>