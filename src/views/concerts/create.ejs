<%- include('../partials/header', { title: 'Create concert' }) %>

<h1>Add Concert</h1>

<form class="stack-form" method="POST" action="/concerts">
  <label for="ConcertName">Concert Name</label>
  <input id="ConcertName" name="ConcertName" type="text" required maxlength="150" />

  <label for="venue">Location</label>
  <input id="venue" name="venue" type="text" required maxlength="120" />

  <label for="ConcertDate">Date</label>
  <input id="ConcertDate" name="ConcertDate" type="date" required />

  <label for="totalSeats">Total Seats</label>
  <input id="totalSeats" name="totalSeats" type="number" min="1" required />

  <label for="price">Price</label>
  <input id="price" name="price" type="number" min="1" step="0.01" required />

  <label for="imageUrl">Poster Image URL</label>
  <input id="imageUrl" name="imageUrl" type="url" placeholder="https://example.com/poster.jpg" />
  
  <label for="ArtistIds">Artists (Select multiple people)</label>
  <select id="ArtistIds" name="ArtistIds" multiple required size="6">
    <% (artists || []).forEach(function (artist) { %>
      <option value="<%= artist.id %>"><%= artist.ArtistName %></option>
    <% }); %>
  </select>
  <small class="help-text">Select multiple people: Push Ctrl/Cmd + Click</small>
  <div id="selected-artist-tags" class="selected-tags"></div>

  <div class="action-row">
    <button class="btn-primary" type="submit">Save</button>
    <a class="btn-ghost" href="/concerts">Cancle</a>
  </div>
</form>

<script>
  (function () {
    const select = document.getElementById('ArtistIds');
    const tagsWrap = document.getElementById('selected-artist-tags');

    function renderTags() {
      tagsWrap.innerHTML = '';
      Array.from(select.selectedOptions).forEach((option) => {
        const tag = document.createElement('span');
        tag.className = 'selected-tag';
        tag.innerHTML = `${option.text} <button type="button" aria-label="remove">×</button>`;

        tag.querySelector('button').addEventListener('click', () => {
          option.selected = false;
          renderTags();
        });

        tagsWrap.appendChild(tag);
      });
    }

    select.addEventListener('change', renderTags);
    renderTags();
  })();
</script>

<%- include('../partials/footer') %>
