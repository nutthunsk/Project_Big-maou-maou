<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title || 'Project Big maou maou' %></title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="site-body">
  <header class="app-header">
    <nav class="top-nav">
      <a class="brand">BIG MAOU MAOU (Admin)</a>
      <div class="top-links">
        <a href="/admin">Dashboard</a>
        <a href="/artists">Artists</a>
        <a href="/concerts">Concerts</a>
        <a href="/customers">Customers</a>
        <a href="/bookings">Bookings</a>
        <a href="/reports">Reports</a>
      </div>
      <button type="button" id="themeToggleBtn" class="btn-ghost btn-small admin-theme-toggle">Dark</button>
    </nav>
  </header>

  <main class="page-shell">
    <% if (flash && flash.success) { %>
      <div class="flash flash-success"><%= flash.success %></div>
    <% } %>

    <% if (flash && flash.error) { %>
      <div class="flash flash-error"><%= flash.error %></div>
    <% } %>

<script>
  (() => {
    const storageKey = 'site-theme';
    const root = document.documentElement;
    const btn = document.getElementById('themeToggleBtn');

    const applyTheme = (theme) => {
      root.setAttribute('data-theme', theme);
      if (!btn) return;
      btn.textContent = theme === 'light' ? 'Light' : 'Dark';
    };

    const savedTheme = localStorage.getItem(storageKey);
    const theme = savedTheme === 'light' ? 'light' : 'dark';
    applyTheme(theme);

    if (!btn) return;
    btn.addEventListener('click', () => {
      const current = root.getAttribute('data-theme') || 'dark';
      const next = current === 'dark' ? 'light' : 'dark';
      localStorage.setItem(storageKey, next);
      applyTheme(next);
    });
  })();
</script>