<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title || 'Big Maou Maou User Site' %></title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="site-body user-site">
  <header class="app-header user-app-header">
    <nav class="top-nav user-top-nav">
      <a class="brand user-brand" href="/user">BIG MAOU MAOU</a>

      <div class="user-nav-right">
        <div class="top-links user-top-links">
          <a href="/user">หน้าแรก</a>
          <a href="/user/artists">ศิลปิน</a>
          <a href="/user/concerts">คอนเสิร์ต</a>
          <% if (authCustomer) { %><a href="/user/profile">My Profile</a><% } %>

              <div class="user-account-box">
          <% if (authCustomer) { %>
            <span class="muted-inline">Hi, <%= authCustomer.fullname %></span>
            <form method="POST" action="/user/logout" class="inline-form">
              <button type="submit" class="btn-inline btn-small">Logout</button>
            </form>
          <% } else { %>
            <a href="/user/login" class="btn-inline btn-small">Login</a>
          <% } %>
      </div>
 </div>

<button type="button" id="themeToggleBtn" class="btn-ghost btn-small user-theme-toggle">Dark</button>

    </nav>
  </header>

  <main class="page-shell user-page-shell">
    <% if (flash && flash.success) { %>
      <div class="flash flash-success"><%= flash.success %></div>
    <% } %>

    <% if (flash && flash.error) { %>
      <div class="flash flash-error"><%= flash.error %></div>
    <% } %>

<script>
  (() => {
    const storageKey = 'user-theme';
    const root = document.documentElement;
    const btn = document.getElementById('themeToggleBtn');

    const applyTheme = (theme) => {
      root.setAttribute('data-user-theme', theme);
      if (!btn) return;
      btn.textContent = theme === 'light' ? 'Light' : 'Dark';
    };

    const savedTheme = localStorage.getItem(storageKey);
    const theme = savedTheme === 'light' ? 'light' : 'dark';
    applyTheme(theme);

    if (!btn) return;
    btn.addEventListener('click', () => {
      const current = root.getAttribute('data-user-theme') || 'dark';
      const next = current === 'dark' ? 'light' : 'dark';
      localStorage.setItem(storageKey, next);
      applyTheme(next);
    });
  })();
</script>