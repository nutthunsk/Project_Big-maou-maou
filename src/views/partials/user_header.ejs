<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title || 'Big Maou Maou User Site' %></title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="site-body">
  <header class="app-header">
    <nav class="top-nav">
      <a class="brand">BIG MAOU MAOU</a>
      <div class="top-links">
        <a href="/user">Home</a>
        <a href="/user/artists">Artists</a>
        <a href="/user/concerts">Concerts</a>
      </div>
    </nav>
  </header>

  <main class="page-shell">
    <% if (flash && flash.success) { %>
      <div class="flash flash-success"><%= flash.success %></div>
    <% } %>

    <% if (flash && flash.error) { %>
      <div class="flash flash-error"><%= flash.error %></div>
    <% } %>