<!DOCTYPE html>
<html>
<head>
  <title>Customers</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="dark-theme">
  <h1>ลูกค้า (Customers)</h1>

  <div class="action-row">
    <a class="btn-inline" href="/customers/report">ดูรายงานลูกค้า</a>
    <a class="btn-inline" href="/customers/api" target="_blank">เปิด JSON API</a>
  </div>

  <% if (customerRows.length === 0) { %>
    <p>ยังไม่มีข้อมูลลูกค้า</p>
  <% } else { %>
    <table class="booking-table">
      <thead>
        <tr>
          <th>#</th>
          <th>ชื่อ-นามสกุล</th>
          <th>อีเมล</th>
          <th>เบอร์โทร</th>
          <th>จำนวนการจอง</th>
          <th>จองแล้วชำระ</th>
          <th>ยอดชำระสะสม</th>
          <th>จองล่าสุด</th>
        </tr>
      </thead>
      <tbody>
        <% customerRows.forEach((row, idx) => { %>
          <tr>
            <td><%= idx + 1 %></td>
            <td><%= row.customer.fullname %></td>
            <td><%= row.customer.email %></td>
            <td><%= row.customer.phoneNumber %></td>
            <td><%= row.totalBookings %></td>
            <td><%= row.paidBookings %></td>
            <td><%= row.totalSpent.toLocaleString() %> บาท</td>
            <td><%= row.lastBookingDate ? row.lastBookingDate.toLocaleString("th-TH") : "-" %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>

  <a href="/concerts" class="back-link">← กลับหน้าคอนเสิร์ต</a>
</body>
</html>