<%- include('../partials/header', { title: 'Edit artist' }) %>

<h1>Edit Artist</h1>
<form class="stack-form" method="POST" action="/artists/<%= artist.id %>">
  <input type="hidden" name="_method" value="PUT" />

  <label for="ArtistName">Artist Name</label>
  <input id="ArtistName" name="ArtistName" type="text" value="<%= artist.ArtistName %>" required maxlength="120" />

  <label for="genre">Genre</label>
  <input id="genre" name="genre" type="text" value="<%= artist.genre %>" required maxlength="120" />

  <div class="action-row">
    <button class="btn-primary" type="submit">Update</button>
    <button class="btn-ghost" type="button" onclick="if (window.history.length > 1) { window.history.back(); } else { window.location.href='/artists'; }">Cancle</button>
  </div>
</form>

<%- include('../partials/footer') %>