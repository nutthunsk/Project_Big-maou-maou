<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>แก้ไขศิลปิน/ผู้จัด</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="site-body">
  <main class="page-shell form-shell">
    <h1>แก้ไขศิลปิน / ผู้จัด</h1>

   <form class="stack-form" action="/artists/edit/<%= artist.id %>" method="POST">
      <label>ชื่อศิลปิน/ผู้จัด</label>
      <input type="text" name="ArtistName" value="<%= artist.ArtistName %>" required>

   <label>แนวเพลง/ประเภท</label>
      <input type="text" name="genre" value="<%= artist.genre %>">

      <div class="action-row">
        <button class="btn-primary btn-small" type="submit">อัปเดต</button>
        <a href="/artists" class="btn-ghost btn-small">ย้อนกลับ</a>
      </div>
    </form>
  </main>
</body>
</html>