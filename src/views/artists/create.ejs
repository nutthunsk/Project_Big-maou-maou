<%- include('../partials/header', { title: 'Create artist' }) %>

<h1>เพิ่ม Artist</h1>

<form class="stack-form" method="POST" action="/artists">
  <label for="ArtistName">ชื่อศิลปิน</label>
  <input id="ArtistName" name="ArtistName" type="text" required maxlength="120" />

  <label for="genre">Genre</label>
  <input id="genre" name="genre" type="text" required maxlength="120" />

  <div class="action-row">
    <button class="btn-primary" type="submit">บันทึก</button>
    <a class="btn-ghost" href="/artists">ยกเลิก</a>
  </div>
</form>

<%- include('../partials/footer') %>