<%- include('../partials/header', { title: 'Reports' }) %>

<div class="page-head">
  <h1>Report</h1>
</div>

    <!-- ===== filter form ===== -->
    <form method="GET" action="/reports" class="stack-form" style="margin-bottom:20px">
      <div>
        <label>Select report type</label>
        <select name="type" onchange="this.form.submit()">
          <option value="concert" <%= type === 'concert' ? 'selected' : '' %>>
            Concert Sales
          </option>
          <option value="customer" <%= type === 'customer' ? 'selected' : '' %>>
            Customer Spending
          </option>

          <option value="artist" <%= type === 'artist' ? 'selected' : '' %>>
            Artist and Booking
          </option>
        </select>
      </div>

      <% if (type === 'concert') { %>
        <div>
          <label>Booking status</label>
          <select name="status" onchange="this.form.submit()">
            <option value="all" <%= status === 'all' ? 'selected' : '' %>>all</option>
            <option value="pending" <%= status === 'pending' ? 'selected' : '' %>>pending</option>
            <option value="paid" <%= status === 'paid' ? 'selected' : '' %>>paid</option>
          </select>
        </div>
      <% } %>
      <% if (type === 'artist') { %>
        <div>
          <label for="q">Find an artist</label>
          <input id="q" name="q" type="text" placeholder="Type the artist's name..." value="<%= artistQuery || '' %>" />
        </div>
        <div>
          <button class="btn-primary" type="submit">Find</button>
        </div>
      <% } %>
      
    </form>

    <!-- ================= CONCERT REPORT ================= -->
    <% if (type === 'concert') { %>
      <h2>Concert sales report</h2>

      <section class="report-grid">
        <div class="report-card">
          <h3>All concerts</h3>
          <p><%= summary.totalConcerts %></p>
        </div>
        <div class="report-card">
          <h3>All Ticket</h3>
          <p><%= summary.totalTickets %></p>
        </div>
        <div class="report-card">
          <h3>Total income</h3>
          <p><%= Number(summary.totalRevenue).toLocaleString() %> Bath</p>
        </div>
      </section>

      <table class="booking-table">
        <thead>
          <tr>
            <th>Concert</th>
            <th>Artists</th>
            <th>Tickets</th>
            <th>Revenue</th>
          </tr>
        </thead>
        <tbody>
          <% rows.forEach(r => { %>
            <tr>
              <td><%= r.concert.ConcertName %></td>
              <td><%= r.concert.Artists.map(a => a.ArtistName).join(', ') %></td>
              <td><%= r.totalQty %></td>
              <td><%= Number(r.totalRevenue).toLocaleString() %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>

    <!-- ================= CUSTOMER REPORT ================= -->
    <% if (type === 'customer') { %>
      <h2>Customer spending report</h2>

      <section class="report-grid">
        <div class="report-card">
          <h3>Customers</h3>
          <p><%= summary.customerCount %></p>
        </div>
        <div class="report-card">
          <h3>Reservation</h3>
          <p><%= summary.bookingCount %></p>
        </div>
        <div class="report-card">
          <h3>Total income</h3>
          <p><%= Number(summary.revenue).toLocaleString() %> Bath</p>
        </div>
      </section>

      <table class="booking-table">
        <thead>
          <tr>
            <th>Customer</th>
            <th>Email</th>
            <th>Bookings</th>
            <th>Total Spent</th>
          </tr>
        </thead>
        <tbody>
          <% rows.forEach(r => { %>
            <tr>
              <td><%= r.customer.fullname %></td>
              <td><%= r.customer.email %></td>
              <td><%= r.bookings %></td>
              <td><%= Number(r.totalSpent).toLocaleString() %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
    <!-- ================= ARTIST REPORT ================= -->
    <% if (type === 'artist') { %>
      <h2>Artist and booking reports</h2>

      <section class="report-grid">
        <div class="report-card">
          <h3>Artists</h3>
          <p><%= summary.artistCount %></p>
        </div>
        <div class="report-card">
          <h3>Concert</h3>
          <p><%= summary.concertCount %></p>
        </div>
        <div class="report-card">
          <h3>Combined booking</h3>
          <p><%= summary.bookingCount %></p>
        </div>
        <div class="report-card">
          <h3>Total income</h3>
          <p><%= Number(summary.revenue).toLocaleString() %> Bath</p>
        </div>
      </section>

      <table class="booking-table">
        <thead>
          <tr>
            <th>Artist</th>
            <th>Concerts</th>
            <th>Bookings</th>
            <th>Paid</th>
            <th>Revenue</th>
          </tr>
        </thead>
        <tbody>
          <% rows.forEach(r => { %>
            <tr>
              <td><%= r.artist.ArtistName %></td>
              <td><%= r.concertCount %></td>
              <td><%= r.bookingCount %></td>
              <td><%= r.paidCount %></td>
              <td><%= Number(r.revenue).toLocaleString() %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>

  </main>
</body>

<%- include('../partials/footer') %>