<%- include('../partials/header', { title: 'Concert Sales Report' }) %>

<div class="page-head">
  <h1>รายงานยอดขายคอนเสิร์ต</h1>
</div>

<form class="stack-form" method="GET" action="/reports/concert-sales">
  <label for="status">กรองสถานะการจอง</label>
  <select id="status" name="status">
    <option value="all" <%= status === 'all' ? 'selected' : '' %>>ทั้งหมด</option>
    <option value="pending" <%= status === 'pending' ? 'selected' : '' %>>pending</option>
    <option value="paid" <%= status === 'paid' ? 'selected' : '' %>>paid</option>
    <option value="cancelled" <%= status === 'cancelled' ? 'selected' : '' %>>cancelled</option>
  </select>
  <button class="btn-primary" type="submit">ดูรายงาน</button>
</form>

<section class="report-grid">
  <article class="report-card"><h3>จำนวนคอนเสิร์ต</h3><p><%= summary.totalConcerts %></p></article>
  <article class="report-card"><h3>จำนวนบัตร</h3><p><%= summary.totalTickets %></p></article>
  <article class="report-card"><h3>ยอดรวม</h3><p><%= Number(summary.totalRevenue).toLocaleString() %> บาท</p></article>
</section>

<table class="booking-table">
  <thead>
    <tr>
      <th>Concert</th>
      <th>Artists</th>
      <th>Tickets</th>
      <th>Revenue</th>
    </tr>
  </thead>
  <tbody>
    <% if (!rows.length) { %>
      <tr><td colspan="4" class="empty-state">ไม่พบข้อมูล</td></tr>
    <% } %>

    <% rows.forEach((row) => { %>
      <tr>
        <td><%= row.concert.ConcertName %></td>
        <td><%= row.concert.Artists.map((artist) => artist.ArtistName).join(', ') %></td>
        <td><%= row.totalQty %></td>
        <td><%= Number(row.totalRevenue).toLocaleString() %></td>
      </tr>
    <% }) %>
  </tbody>
</table>

<%- include('../partials/footer') %>